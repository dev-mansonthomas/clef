# ============================================================================
# CLEF - Configuration Frontend
# ============================================================================
# Copier ce fichier vers .env et remplir les valeurs appropriées
# pour votre environnement (dev, test, ou prod)

# ----------------------------------------------------------------------------
# Environnement
# ----------------------------------------------------------------------------
# Environnement actuel: dev, test, ou prod
ENVIRONMENT=dev

# ----------------------------------------------------------------------------
# API Backend
# ----------------------------------------------------------------------------
# URL de l'API backend
# - Dev local: http://localhost:8000
# - Cloud Run: https://clef-api-{hash}.run.app
API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Domaine & URLs
# ----------------------------------------------------------------------------
# Domaine principal de l'application
DOMAIN=clef.example.com

# URL de l'app formulaire (bénévoles)
APP_FORM_URL=https://clef.example.com

# URL de l'app administration (responsables)
APP_ADMIN_URL=https://admin.clef.example.com

# ----------------------------------------------------------------------------
# Authentification Google OAuth
# ----------------------------------------------------------------------------
# Configuration SSO Google OAuth pour @croix-rouge.fr
GOOGLE_DOMAIN=croix-rouge.okta.com
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXX
GOOGLE_REDIRECT_URI=https://clef.example.com/callback

# Issuer URL Google OAuth
GOOGLE_ISSUER=https://croix-rouge.okta.com/oauth2/default

# Scopes OAuth2 requis
GOOGLE_SCOPES=openid profile email

# ----------------------------------------------------------------------------
# Google Cloud Platform
# ----------------------------------------------------------------------------
# Projet GCP selon l'environnement (pour analytics, monitoring)
# - dev: rcq-fr-dev
# - test: rcq-fr-test
# - prod: rcq-fr-prod
GCP_PROJECT=rcq-fr-dev

# ----------------------------------------------------------------------------
# PWA Configuration
# ----------------------------------------------------------------------------
# Nom de l'application (affiché dans le manifest)
APP_NAME=CLEF - Gestion Véhicules

# Nom court (affiché sur l'écran d'accueil)
APP_SHORT_NAME=CLEF

# Description de l'application
APP_DESCRIPTION=Gestion des véhicules Croix-Rouge - Prise/Retour et Administration

# Couleur du thème (Material Design)
THEME_COLOR=#E30613

# Couleur de fond
BACKGROUND_COLOR=#FFFFFF

# ----------------------------------------------------------------------------
# Features Flags
# ----------------------------------------------------------------------------
# Activer le mode offline (PWA)
ENABLE_OFFLINE_MODE=true

# Activer les notifications push (future feature)
ENABLE_PUSH_NOTIFICATIONS=false

# Activer le mode debug (logs détaillés dans la console)
ENABLE_DEBUG_MODE=false

# ----------------------------------------------------------------------------
# Upload & Stockage
# ----------------------------------------------------------------------------
# Taille maximale des photos (en MB)
MAX_PHOTO_SIZE_MB=10

# Nombre maximum de photos par formulaire
MAX_PHOTOS_PER_FORM=10

# Formats de photos acceptés (séparés par des virgules)
ACCEPTED_PHOTO_FORMATS=image/jpeg,image/png,image/webp

# ----------------------------------------------------------------------------
# QR Code
# ----------------------------------------------------------------------------
# Activer le scan de QR code
ENABLE_QR_SCAN=true

# Timeout du scan QR (en secondes)
QR_SCAN_TIMEOUT=30

# ----------------------------------------------------------------------------
# Cache & Performance
# ----------------------------------------------------------------------------
# Durée de cache des référentiels (en secondes, défaut: 1 heure)
CACHE_DURATION_REFERENTIELS=3600

# Durée de cache des véhicules (en secondes, défaut: 5 minutes)
CACHE_DURATION_VEHICULES=300

# ----------------------------------------------------------------------------
# Analytics & Monitoring (optionnel)
# ----------------------------------------------------------------------------
# Google Analytics ID (si utilisé)
GA_TRACKING_ID=

# Sentry DSN pour error tracking (si utilisé)
SENTRY_DSN=


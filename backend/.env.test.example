# ============================================================================
# CLEF - Configuration Backend - ENVIRONNEMENT TEST (GCP rcq-fr-test)
# ============================================================================
# Copier ce fichier vers .env.test et remplir les valeurs appropriées
# pour l'environnement de test GCP

# ----------------------------------------------------------------------------
# Environnement
# ----------------------------------------------------------------------------
# Environnement actuel: test
ENVIRONMENT=test

# ----------------------------------------------------------------------------
# Google Cloud Platform
# ----------------------------------------------------------------------------
# Projet GCP pour TEST
GCP_PROJECT=rcq-fr-test

# Région GCP pour les ressources
GCP_REGION=europe-west1

# Préfixe pour toutes les ressources GCP (OBLIGATOIRE: clef-)
GCP_RESOURCE_PREFIX=clef-

# ----------------------------------------------------------------------------
# Domaine & URLs
# ----------------------------------------------------------------------------
# Domaine principal de l'application TEST
# - App Formulaire (bénévoles): {DOMAIN}
# - App Administration (responsables): admin.{DOMAIN}
DOMAIN=clef-test.example.com

# URL de base de l'API (généré automatiquement en Cloud Run)
API_URL=https://clef-api-{hash}.run.app

# ----------------------------------------------------------------------------
# Redis / MemoryStore
# ----------------------------------------------------------------------------
# URL de connexion Redis (MemoryStore avec persistence activée)
# Format: redis://[username]:[password]@[host]:[port]/[db]
# Exemple: redis://:password@10.0.0.3:6379/0
REDIS_URL=redis://localhost:6379/0

# TTL du cache pour les référentiels (en secondes, défaut: 1 an)
CACHE_TTL_REFERENTIELS=31536000

# ----------------------------------------------------------------------------
# Valkey (Memorystore) Configuration
# ----------------------------------------------------------------------------
# Memory size in GB for Valkey instance
VALKEY_MEMORY_GB=1

# Node type: SHARED_CORE_NANO, STANDARD_SMALL, HIGHMEM_MEDIUM, HIGHMEM_XLARGE
VALKEY_NODE_TYPE=SHARED_CORE_NANO

# Number of replicas per shard (1 recommended for HA)
VALKEY_REPLICA_COUNT=1

# Valkey version: VALKEY_8_0
VALKEY_VERSION=VALKEY_8_0

# Zone distribution mode: MULTI_ZONE or SINGLE_ZONE
VALKEY_ZONE_MODE=MULTI_ZONE

# ----------------------------------------------------------------------------
# Sync API (Google Apps Script)
# ----------------------------------------------------------------------------
# API Key for Google Apps Script authentication
# Generate a secure random string: openssl rand -hex 32
SYNC_API_KEY=CHANGE_ME_TO_RANDOM_STRING_IN_PRODUCTION

# ----------------------------------------------------------------------------
# Google Sheets - Référentiels
# ----------------------------------------------------------------------------
# IMPORTANT: Utiliser les copies TEST des fichiers Google Sheets

# Référentiel Véhicules (19 colonnes + onglet "Metadata CLEF")
# Contient: immatriculation, CT, assurance, Drive links, couleur calendrier
SHEETS_URL_VEHICULES=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/edit

# Référentiel Bénévoles (export SI Croix-Rouge)
# Utilisé pour déterminer l'UL d'un bénévole
SHEETS_URL_BENEVOLES=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/edit

# Référentiel Responsables (responsables UL, activités spécialisées, DT)
SHEETS_URL_RESPONSABLES=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/edit

# Template pour documents véhicule
TEMPLATE_DOCUMENT_VEHICULE_URL=https://docs.google.com/document/d/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/edit

# ----------------------------------------------------------------------------
# Google Calendar - Réservations
# ----------------------------------------------------------------------------
# Nom du calendrier pour TEST
CALENDAR_NAME_PREFIX=TEST - CLEF

# ----------------------------------------------------------------------------
# Authentification Google OAuth
# ----------------------------------------------------------------------------
# Configuration SSO Google OAuth pour @croix-rouge.fr
GOOGLE_DOMAIN=croix-rouge.okta.com
GOOGLE_CLIENT_ID=XXXXXXXXXXXXXXXXXX
GOOGLE_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_REDIRECT_URI=https://clef-test.example.com/callback

# Issuer URL Google OAuth
GOOGLE_ISSUER=https://croix-rouge.okta.com/oauth2/default

# ----------------------------------------------------------------------------
# Google APIs - Compte de Service
# ----------------------------------------------------------------------------
# IMPORTANT: Requis quand USE_MOCKS=false
# Le compte de service doit avoir accès à:
# - Google Calendar API
# - Google Sheets API
# - Google Drive API
# - Gmail API

# Option 1: Chemin vers le fichier JSON des credentials du compte de service
# Recommandé pour développement local
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Option 2: Credentials encodés en base64 (pour déploiements cloud)
# Utilisé si GOOGLE_APPLICATION_CREDENTIALS n'est pas défini
# Pour encoder: base64 -i service-account.json | tr -d '\n'
GOOGLE_CREDENTIALS_BASE64=

# Email du compte de service (pour délégation) - TEST
SERVICE_ACCOUNT_EMAIL=clef-service@rcq-fr-test.iam.gserviceaccount.com

# ----------------------------------------------------------------------------
# Super Admin Configuration
# ----------------------------------------------------------------------------
# Le super admin est le premier administrateur qui configure l'application
# Il sera automatiquement redirigé vers l'autorisation Calendar/Drive/Gmail au login
SUPER_ADMIN_EMAIL=thomas.manson@croix-rouge.fr
SUPER_ADMIN_DT_ID=DT75
SUPER_ADMIN_DT_NUMERIC_ID=80

# ----------------------------------------------------------------------------
# Email & Alertes
# ----------------------------------------------------------------------------
# Email du gestionnaire DT (expéditeur des alertes)
EMAIL_GESTIONNAIRE_DT=thomas.manson@croix-rouge.fr

# Email destinataire des alertes (configurable via l'interface)
EMAIL_DESTINATAIRE_ALERTES=Magalie.WERNER@s2hgroup.com

# Délai d'alerte pour CT/Antipollution (en jours, défaut: 60 = 2 mois)
ALERT_DELAY_DAYS=60

# ----------------------------------------------------------------------------
# Scheduler (Alertes automatiques)
# ----------------------------------------------------------------------------
# Activer/désactiver le scheduler (défaut: true)
SCHEDULER_ENABLED=true

# Heure d'exécution du job d'alertes (format 24h, défaut: 8h00)
ALERT_CRON_HOUR=8
ALERT_CRON_MINUTE=0

# ----------------------------------------------------------------------------
# Sécurité
# ----------------------------------------------------------------------------
# Clé secrète pour génération des QR codes (SALT)
# IMPORTANT: Générer une valeur aléatoire unique par environnement
QR_CODE_SALT=CHANGE_ME_TO_RANDOM_STRING_IN_PRODUCTION

# Clé secrète pour la session cookie (chiffrement)
# IMPORTANT: Générer une valeur aléatoire unique par environnement
# Exemple: openssl rand -hex 32
SESSION_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING_IN_PRODUCTION

# Clé secrète pour JWT (si utilisé)
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_IN_PRODUCTION

# CORS - Origines autorisées (séparées par des virgules)
# TEST: URLs de l'environnement de test
CORS_ORIGINS=https://clef-test.example.com,https://admin.clef-test.example.com

# ----------------------------------------------------------------------------
# Logging & Monitoring
# ----------------------------------------------------------------------------
# Niveau de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Format de log: json ou text
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Port d'écoute de l'API (local dev uniquement, Cloud Run utilise PORT env var)
PORT=8000

# Mode debug (désactiver en production)
DEBUG=false

# ----------------------------------------------------------------------------
# Services Mock (Développement)
# ----------------------------------------------------------------------------
# Utiliser les services mock au lieu des vrais services Google
# true: Utilise des données de test codées en dur (pas besoin de Service Account)
# false: Utilise les vrais services Google (GOOGLE_APPLICATION_CREDENTIALS requis)
USE_MOCKS=false



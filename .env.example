# CLEF - Environment Configuration Example
# Copy this file to .env and fill in the values

# Environment (dev, test, prod)
ENV=dev

# GCP Project
GCP_PROJECT=rcq-fr-dev

# Redis Configuration (for local development, these are set by docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Domain Configuration
DOMAIN=clef.example.com

# API URLs (for frontend)
API_URL=http://localhost:8000

# Google APIs (to be configured later)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google OAuth Configuration
# Configure in Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID for Web application
# Add authorized redirect URI: https://your-domain.com/auth/callback (or http://localhost:8000/auth/callback for dev)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# DT Manager Email (user with full admin access)
EMAIL_GESTIONNAIRE_DT=thomas.manson@croix-rouge.fr

# Session Secret (change in production!)
SESSION_SECRET_KEY=dev-secret-key-change-in-production

# Sync API Key (for Google Apps Script integration)
SYNC_API_KEY=your-sync-api-key-change-in-production

